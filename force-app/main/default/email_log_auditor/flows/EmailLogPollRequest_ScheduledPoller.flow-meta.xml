<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>Record-Triggered Flow on EmailLogPollRequest__c. Fires a scheduled path at ScheduledTime__c (set to NOW+1min on record creation by Apex). Calls EmailLogPollService.pollStatus() which enqueues EmailLogPollQueueable. All poll logic (HTTP callout, clone creation, ready detection, download dispatch) is handled asynchronously in the Queueable where a valid VF session ID is available.</description>
    <label>Email Log Poll Request — Scheduled Poller</label>

    <actionCalls>
        <name>EnqueuePollJob</name>
        <label>Enqueue Poll Job</label>
        <locationX>182</locationX>
        <locationY>134</locationY>
        <actionName>EmailLogPollService</actionName>
        <actionType>apex</actionType>
        <inputParameters>
            <name>pollRequestId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
    </actionCalls>

    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>

    <processType>AutoLaunchedFlow</processType>

    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <object>EmailLogPollRequest__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <scheduledPaths>
            <name>PollAtScheduledTime</name>
            <connector>
                <targetReference>EnqueuePollJob</targetReference>
            </connector>
            <label>Poll at Scheduled Time</label>
            <maxBatchSize>200</maxBatchSize>
            <offsetNumber>0</offsetNumber>
            <offsetUnit>Minutes</offsetUnit>
            <recordField>ScheduledTime__c</recordField>
            <timeSource>RecordField</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>

    <status>Active</status>

</Flow>
