<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PollStatus__c</fullName>
    <description>Current state of this poll attempt. Pending = file still generating; Ready = file available for download (download triggered); TimedOut = max attempts reached; Failed = overview page returned an error.</description>
    <label>Poll Status</label>
    <required>true</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Pending</fullName>
                <default>true</default>
                <label>Pending</label>
            </value>
            <value>
                <fullName>Ready</fullName>
                <default>false</default>
                <label>Ready</label>
            </value>
            <value>
                <fullName>TimedOut</fullName>
                <default>false</default>
                <label>Timed Out</label>
            </value>
            <value>
                <fullName>Failed</fullName>
                <default>false</default>
                <label>Failed</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
