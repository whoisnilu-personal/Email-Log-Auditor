<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>RequestDirection__c</fullName>
    <description>Email direction to include in the log request. Maps to the Direction field on the Salesforce Email Log Request form. Defaults to Outbound.</description>
    <fieldManageability>SubscriberControlled</fieldManageability>
    <label>Request Direction</label>
    <required>false</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value><fullName>Outbound</fullName><default>true</default><label>Outbound</label></value>
            <value><fullName>Inbound</fullName><default>false</default><label>Inbound</label></value>
            <value><fullName>Both</fullName><default>false</default><label>Both</label></value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
