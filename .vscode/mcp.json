{
    "servers": {
        "Salesforce DX": {
            "command": "npx",
            "args": [
                "-y",
                "@salesforce/mcp@latest",
                "--orgs",
                "DEFAULT_TARGET_ORG",
                "--toolsets",
                "orgs,metadata,data,users,testing,lwc-experts,aura-experts,experts-validation",
                "--allow-non-ga-tools"
            ]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": [
                "-y", 
                "chrome-devtools-mcp@latest"
            ]
        }
    }
}